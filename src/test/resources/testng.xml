<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="OrangeHRM Automation Suite" parallel="methods" thread-count="4">

    <listeners>
        <listener class-name="dev.valvar.orangehrm.listener.AnnotationTransformer"/>
        <listener class-name="dev.valvar.orangehrm.listener.TestListener"/>
    </listeners>

    <test name="UI Tests on Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="dev.valvar.orangehrm.test.AuthorizationTest"/>
            <class name="dev.valvar.orangehrm.test.PimTest"/>
            <class name="dev.valvar.orangehrm.test.LeaveTest"/>
            <class name="dev.valvar.orangehrm.test.AdminTest"/>
            <class name="dev.valvar.orangehrm.test.RecruitmentTest"/>
            <class name="dev.valvar.orangehrm.test.MyInfoTest"/>
        </classes>
    </test>

</suite>